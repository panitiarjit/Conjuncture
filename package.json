{
  "name": "conjuncture",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "scrape": "ts-node --project tsconfig.scripts.json scripts/scrape-egp.ts",
    "scrape:dry": "ts-node --project tsconfig.scripts.json scripts/scrape-egp.ts --dry",
    "fetch-cgd": "ts-node --project tsconfig.scripts.json scripts/fetch-cgd.ts",
    "fetch-cgd:dry": "ts-node --project tsconfig.scripts.json scripts/fetch-cgd.ts --dry"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.19.11",
    "chromium-bidi": "^16.0.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^12.7.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "rebrowser-playwright": "^1.52.0",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.6.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wrangler": "^4.93.0"
  }
}
